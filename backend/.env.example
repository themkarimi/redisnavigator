NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://redisnavigator:redisnavigator_secret@localhost:5432/redisnavigator_db
JWT_ACCESS_SECRET=your_access_token_secret_change_this_in_production
JWT_REFRESH_SECRET=your_refresh_token_secret_change_this_in_production
ENCRYPTION_KEY=your_32_char_encryption_key_here!
REDIS_BLACKLIST_URL=redis://localhost:6379
REDIS_BLACKLIST_PASSWORD=
FRONTEND_URL=http://localhost:3000
OIDC_ENABLED=false
OIDC_ISSUER_URL=https://your-oidc-provider.example.com
OIDC_CLIENT_ID=your_client_id
OIDC_CLIENT_SECRET=your_client_secret
OIDC_REDIRECT_URI=http://localhost:4000/api/auth/oidc/callback
# Optional: path to a YAML file for configuration-as-code (connections, groups, permissions)
# Setting CONFIG_FILE also enables config-as-code mode, which disables UI-driven
# creation, editing, and deletion of connections and groups.
CONFIG_FILE=
# Optional: comma-separated list of Redis commands to disable (e.g. SCAN,FLUSHDB,FLUSHALL)
# These commands will be blocked in the CLI and key browser.
DISABLED_COMMANDS=
