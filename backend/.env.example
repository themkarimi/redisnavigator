NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://redisgui:redisgui_secret@localhost:5432/redisgui_db
JWT_ACCESS_SECRET=your_access_token_secret_change_this_in_production
JWT_REFRESH_SECRET=your_refresh_token_secret_change_this_in_production
ENCRYPTION_KEY=your_32_char_encryption_key_here!
REDIS_BLACKLIST_URL=redis://localhost:6379
REDIS_BLACKLIST_PASSWORD=
FRONTEND_URL=http://localhost:3000
OIDC_ENABLED=false
OIDC_ISSUER_URL=https://your-oidc-provider.example.com
